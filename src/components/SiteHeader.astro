---
/**
 * SiteHeader — 풀폭 sticky 헤더.
 * 브랜드 "최경찬"(크림슨 닷) + 내비.
 * activeNav: 'home' | 'about' | 'blog' | 'resources' 중 현재 페이지를 강조.
 */
interface Props {
  activeNav?: 'home' | 'about' | 'blog' | 'resources';
}
const { activeNav } = Astro.props;

const links = [
  { key: 'home', href: '/', label: '홈' },
  { key: 'about', href: '/about', label: '소개' },
  { key: 'blog', href: '/blog', label: '글' },
  { key: 'resources', href: '/자료', label: '자료' },
] as const;
---

<header class="site-header" id="siteHeader">
  <div class="wrap nav">
    <a class="brand-mark" href="/" aria-label="홈"><span class="brand-dot" aria-hidden="true"></span>최경찬</a>
    <nav class="nav-links" aria-label="주요">
      {links.map((l) => (
        <a href={l.href} aria-current={activeNav === l.key ? 'page' : undefined}>{l.label}</a>
      ))}
      <a class="nav-gh" href="https://github.com/repairer5812" target="_blank" rel="noopener" aria-label="GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/></svg>
        <span class="nav-label-hide">GitHub</span>
      </a>
    </nav>
  </div>
</header>
