---
/**
 * Comments — Giscus(GitHub Discussions) 댓글.
 * pathname 매핑 → 글 경로별 Discussion 1개.
 * 라이트 테마, 한국어. script는 클라이언트에서 비동기 로드.
 */
---

<section class="comments" aria-label="댓글">
  <h2 class="comments-title">댓글</h2>
  <div class="giscus"></div>
  <script
    src="https://giscus.app/client.js"
    data-repo="repairer5812/repairer5812.github.io"
    data-repo-id="R_kgDOSOs9Yg"
    data-category="Announcements"
    data-category-id="DIC_kwDOSOs9Ys4C_w3f"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="light"
    data-lang="ko"
    crossorigin="anonymous"
    async></script>
</section>
