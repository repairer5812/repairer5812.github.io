---
import Base from '../layouts/Base.astro';
import projects from '../data/projects.json';

const featured = projects.find((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
---

<Base activeNav="home">
  <span id="top"></span>

  <!-- ===== Hero ===== -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-text">
        <span class="status reveal"><span class="pulse" aria-hidden="true"></span>고려대 SW·AI 융합대학원 석사과정 · 61기</span>
        <h1 class="reveal" style="--d:.05s">
          만들면서 이해하는<br><span class="accent-stop">AI</span> 대학원생<span class="name-en">Kyungchan Choi · 최경찬</span>
        </h1>
        <p class="lede reveal" style="--d:.12s">
          <b>LLM, AI4Science, 멀티모달</b>을 공부하며, 직접 쓰는 학습 도구와 연구 인텔리전스 사이트를 만듭니다. 트렌드보다 <b>객관 지표</b>로 검증합니다.
        </p>
        <div class="tags reveal" style="--d:.18s">
          <span class="tag">LLM</span>
          <span class="tag">AI4Science</span>
          <span class="tag">Multimodal</span>
          <span class="tag">RL <span class="tag-soon">관심 중</span></span>
        </div>
        <div class="hero-actions reveal" style="--d:.24s">
          <a class="btn btn-primary" href="#work">만든 것 보기
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="btn btn-ghost" href="mailto:repairer5812@gmail.com">연락하기</a>
        </div>
        <div class="hero-contacts reveal" style="--d:.3s">
          <a href="mailto:repairer5812@gmail.com">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            repairer5812@gmail.com
          </a>
          <a href="tel:+821028753705">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M5 4h4l2 5-3 2a14 14 0 0 0 6 6l2-3 5 2v4a2 2 0 0 1-2 2A17 17 0 0 1 3 6a2 2 0 0 1 2-2Z"/></svg>
            010-2875-3705
          </a>
        </div>
      </div>

      <div class="hero-art reveal" style="--d:.16s" aria-hidden="true">
        <div class="glow"></div>
        <svg viewBox="0 0 400 400" role="img" aria-label="신경망(딥러닝) 순전파 모티프">
          <line class="edge" x1="60" y1="131" x2="158" y2="108"/>
          <line class="edge" x1="60" y1="131" x2="158" y2="154"/>
          <line class="edge" x1="60" y1="131" x2="158" y2="200"/>
          <line class="edge" x1="60" y1="131" x2="158" y2="246"/>
          <line class="edge" x1="60" y1="131" x2="158" y2="292"/>
          <line class="edge" x1="60" y1="177" x2="158" y2="108"/>
          <line class="edge" x1="60" y1="177" x2="158" y2="154"/>
          <line class="edge" x1="60" y1="177" x2="158" y2="246"/>
          <line class="edge" x1="60" y1="177" x2="158" y2="292"/>
          <line class="edge" x1="60" y1="223" x2="158" y2="108"/>
          <line class="edge" x1="60" y1="223" x2="158" y2="154"/>
          <line class="edge" x1="60" y1="223" x2="158" y2="200"/>
          <line class="edge" x1="60" y1="223" x2="158" y2="246"/>
          <line class="edge" x1="60" y1="223" x2="158" y2="292"/>
          <line class="edge" x1="60" y1="269" x2="158" y2="108"/>
          <line class="edge" x1="60" y1="269" x2="158" y2="154"/>
          <line class="edge" x1="60" y1="269" x2="158" y2="200"/>
          <line class="edge" x1="60" y1="269" x2="158" y2="292"/>
          <line class="edge" x1="158" y1="108" x2="256" y2="154"/>
          <line class="edge" x1="158" y1="108" x2="256" y2="200"/>
          <line class="edge" x1="158" y1="108" x2="256" y2="246"/>
          <line class="edge" x1="158" y1="154" x2="256" y2="154"/>
          <line class="edge" x1="158" y1="154" x2="256" y2="200"/>
          <line class="edge" x1="158" y1="154" x2="256" y2="246"/>
          <line class="edge" x1="158" y1="200" x2="256" y2="154"/>
          <line class="edge" x1="158" y1="200" x2="256" y2="246"/>
          <line class="edge" x1="158" y1="246" x2="256" y2="154"/>
          <line class="edge" x1="158" y1="246" x2="256" y2="200"/>
          <line class="edge" x1="158" y1="292" x2="256" y2="154"/>
          <line class="edge" x1="158" y1="292" x2="256" y2="200"/>
          <line class="edge" x1="158" y1="292" x2="256" y2="246"/>
          <line class="edge" x1="256" y1="154" x2="350" y2="200"/>
          <line class="edge-live" x1="60" y1="177" x2="158" y2="200"/>
          <line class="edge-live" x1="60" y1="269" x2="158" y2="246"/>
          <line class="edge-live" x1="158" y1="200" x2="256" y2="200"/>
          <line class="edge-live" x1="158" y1="246" x2="256" y2="246"/>
          <line class="edge-live" x1="256" y1="200" x2="350" y2="200"/>
          <line class="edge-live" x1="256" y1="246" x2="350" y2="200"/>
          <circle class="node-idle" cx="60" cy="131" r="7"/>
          <circle class="node-idle" cx="60" cy="177" r="7"/>
          <circle class="node-idle" cx="60" cy="223" r="7"/>
          <circle class="node-idle" cx="60" cy="269" r="7"/>
          <circle class="node-idle" cx="158" cy="108" r="9"/>
          <circle class="node-idle" cx="158" cy="154" r="9"/>
          <circle class="node-active" cx="158" cy="200" r="9"/>
          <circle class="node-active" cx="158" cy="246" r="9"/>
          <circle class="node-idle" cx="158" cy="292" r="9"/>
          <circle class="node-idle" cx="256" cy="154" r="9"/>
          <circle class="node-active" cx="256" cy="200" r="9"/>
          <circle class="node-active" cx="256" cy="246" r="9"/>
          <circle class="node-core" cx="350" cy="200" r="20"/>
          <circle cx="350" cy="200" r="20" fill="none" stroke="var(--accent)" stroke-width="1.5" opacity="0.4"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- ===== About ===== -->
  <section class="section" id="about">
    <div class="wrap">
      <div class="sec-head reveal">
        <h2>소개</h2>
        <p class="sec-note">막연한 트렌드보다 게재·인용·코드 공개 같은 지표로 검증합니다.</p>
      </div>
      <div class="about">
        <p class="about-lead reveal">
          교육 도메인의 응용을 좋아하는 <span class="hl">빌더</span>이자 AI 대학원생입니다.
        </p>
        <div class="about-body reveal" style="--d:.08s">
          <p>
            AI 대학원에서 <strong>LLM, AI4Science, 멀티모달</strong>을 공부하면서 학습 도구와 연구 인텔리전스 사이트를 직접 만들고 있습니다. 막연한 트렌드보다 <strong>객관 지표</strong>(학회 게재, 인용수, 코드 공개)로 검증된 자료를 선호합니다.
          </p>
          <div class="thesis-note">
            <span class="thesis-label">현재 졸업논문 방향</span>
            <em>학교·모바일 유휴 컴퓨팅 풀링 LLM</em>을 주제로 좁히는 중. 선행연구 <b>64편</b>을 검토한 뒤 측정 스터디와 Preemption-aware 스케줄러 하이브리드를 잠정 방향으로 보고 있습니다.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Work ===== -->
  <section class="section" id="work">
    <div class="wrap">
      <div class="sec-head reveal">
        <h2>만든 것</h2>
        <p class="sec-note">지금 라이브로 운영 중. 제목을 누르면 이동합니다.</p>
      </div>

      <div class="projects">
        {featured && (
          <article class="proj-featured reveal">
            <div class="proj-featured-main">
              <span class="proj-flag">
                <svg class="star" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 2.9 6.3 6.9.7-5.1 4.6 1.4 6.7L12 17.8 5.9 20.3l1.4-6.7L2.2 9l6.9-.7z"/></svg>
                대표 작업 · 졸업논문 연계
              </span>
              <h3><a href={featured.url} target="_blank" rel="noopener">{featured.name}</a></h3>
              <div class="proj-path">{featured.url}</div>
              <p class="proj-desc" set:html={featured.desc}></p>
            </div>
            <div class="proj-side">
              <div class="proj-tags" style="border-top:none;margin-top:0;padding-top:0;">
                {featured.tags.map((t) => <span class="chip">{t}</span>)}
              </div>
            </div>
          </article>
        )}

        {rest.map((p, i) => (
          <article class="proj-row reveal" style={`--d:${0.06 * (i + 1)}s`}>
            <div class="row-main">
              <h3><a href={p.url} target="_blank" rel="noopener">{p.name} <span class="arrow" aria-hidden="true">↗</span></a></h3>
              <div class="proj-path">{p.url}</div>
              <p class="proj-desc" set:html={p.desc}></p>
            </div>
            <div class="row-meta">
              {p.tags.map((t) => <span class="chip">{t}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>
