---
import Base from '../layouts/Base.astro';
import resources from '../data/resources.json';

type Resource = {
  title: string;
  url: string;
  category: string;
  note: string;
  tags: string[];
};

const items = resources as Resource[];

// 카테고리 표시 순서를 고정(데이터에 없는 카테고리는 뒤로).
const order = ['강의', '논문', '도구'];
const meta: Record<string, string> = {
  강의: 'YouTube·대학 공개강의 등 영상 중심 학습 자료',
  논문: '구조와 방법을 정한 기준이 되는 원전',
  도구: '구현·재현·실험에 직접 쓰는 라이브러리와 인덱스',
};

const categories = Array.from(new Set(items.map((r) => r.category))).sort(
  (a, b) => {
    const ia = order.indexOf(a);
    const ib = order.indexOf(b);
    return (ia === -1 ? 99 : ia) - (ib === -1 ? 99 : ib);
  }
);

const grouped = categories.map((cat) => ({
  name: cat,
  note: meta[cat] ?? '',
  list: items.filter((r) => r.category === cat),
}));

function hostOf(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return url;
  }
}
---

<Base
  activeNav="resources"
  title="자료 · 최경찬"
  description="LLM, 멀티모달, 선형대수를 공부하며 직접 골라 본 강의·논문·도구 큐레이션."
>
  <div class="wrap">
    <header class="page-head">
      <h1>자료</h1>
      <p class="page-lead">
        AI 대학원에서 공부하며 직접 보고 도움이 된 <b>강의·논문·도구</b>를 모았습니다.
        막연한 인기보다 <b>실제로 읽고 돌려본 것</b>만 남깁니다. 제목을 누르면 새 탭에서 원본으로 이동합니다.
      </p>
    </header>
  </div>

  {grouped.map((group) => (
    <section class="section res-section">
      <div class="wrap">
        <div class="sec-head reveal">
          <h2>{group.name} <span class="res-count">{group.list.length}</span></h2>
          {group.note && <p class="sec-note">{group.note}</p>}
        </div>

        <ul class="res-list">
          {group.list.map((r, i) => (
            <li class="res-item reveal" style={`--d:${0.05 * (i + 1)}s`}>
              <div class="res-main">
                <h3>
                  <a href={r.url} target="_blank" rel="noopener noreferrer">
                    {r.title} <span class="arrow" aria-hidden="true">↗</span>
                  </a>
                </h3>
                <div class="res-host">{hostOf(r.url)}</div>
                <p class="res-note">{r.note}</p>
              </div>
              <div class="res-meta">
                {r.tags.map((t) => <span class="chip">{t}</span>)}
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}
</Base>

<style>
  .page-lead b { color: var(--ink); font-weight: 720; }

  .res-section { padding-block: clamp(2.5rem, 5vw, 4rem); }
  .res-section:first-of-type { padding-top: clamp(1rem, 2vw, 1.5rem); }

  .res-count {
    font-family: var(--mono);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--muted);
    vertical-align: 0.18em;
    margin-left: 0.15rem;
  }

  .res-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--s4);
  }

  .res-item {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2.25rem);
    align-items: start;
    padding: clamp(1.1rem, 2.4vw, 1.7rem);
    border: 1px solid var(--border);
    border-radius: var(--r);
    background: var(--surface);
    transition: border-color 0.25s var(--ease), background 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .res-item:hover {
    border-color: var(--border-strong);
    background: var(--panel);
    transform: translateX(4px);
  }
  @media (prefers-reduced-motion: reduce) {
    .res-item:hover { transform: none; }
  }

  .res-main { min-width: 0; }
  .res-item h3 {
    font-size: clamp(1.08rem, 1.5vw, 1.28rem);
    font-weight: 750;
    letter-spacing: -0.02em;
    line-height: 1.3;
    word-break: keep-all;
  }
  .res-item h3 a {
    color: var(--ink);
    display: inline;
  }
  .res-item h3 a:hover { color: var(--accent); }
  .res-item h3 .arrow {
    display: inline-block;
    color: var(--muted);
    transition: transform 0.25s var(--ease), color 0.25s var(--ease);
  }
  .res-item:hover h3 .arrow {
    transform: translate(3px, -3px);
    color: var(--accent);
  }

  .res-host {
    font-family: var(--mono);
    font-size: 0.76rem;
    color: var(--muted);
    margin-top: 0.35rem;
    word-break: break-all;
  }
  .res-note {
    color: var(--ink-2);
    margin-top: var(--s3);
    font-size: 0.95rem;
    line-height: 1.6;
    text-wrap: pretty;
    word-break: keep-all;
  }

  .res-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: flex-end;
    align-self: start;
    padding-top: 0.2rem;
  }
  .res-meta .chip { background: var(--panel-2); }

  @media (max-width: 760px) {
    .res-item { grid-template-columns: 1fr; gap: var(--s3); }
    .res-meta { justify-content: flex-start; }
  }
</style>
